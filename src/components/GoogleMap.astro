---
interface Props {
  embedUrl: string;
  title?: string;
  height?: string;
}

const {
  embedUrl,
  title = 'All About Floors NW location map',
  height = '400px',
} = Astro.props;
---

<div class="w-full rounded-2xl overflow-hidden shadow-md" style={`height: ${height}`}>
  <iframe
    src={embedUrl}
    width="100%"
    height="100%"
    style="border: 0;"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title={title}
    aria-label={title}
  ></iframe>
</div>
