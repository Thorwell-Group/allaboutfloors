---
import { company } from '@data/company';
import { services, installationServices } from '@data/services';
import { areas } from '@data/areas';
---

<footer class="bg-brand-dark text-gray-300">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 py-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    <!-- Brand column -->
    <div class="lg:col-span-1">
      <div class="mb-4">
        <img
          src="/images/all-about-floors-nw-logo.webp"
          alt="All About Floors NW"
          class="h-10 w-auto max-w-[180px] object-contain mb-1"
          width="180"
          height="40"
          loading="lazy"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div style="display:none" class="items-center gap-3">
          <div class="bg-brand-gold rounded-lg w-10 h-10 flex items-center justify-center font-heading font-bold text-white text-xl">A</div>
          <div>
            <div class="font-heading font-bold text-white leading-none">{company.name}</div>
            <div class="text-brand-gold text-xs">Est. {company.founded}</div>
          </div>
        </div>
      </div>
      <p class="text-sm leading-relaxed mb-5">
        Vancouver's most trusted flooring company with {company.yearsExperience} years of experience. Premium products. Expert installation. Guaranteed satisfaction.
      </p>
      <div class="space-y-2 text-sm">
        <div class="flex items-start gap-2">
          <svg class="w-4 h-4 mt-0.5 text-brand-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <a href={company.googleMapsUrl} target="_blank" rel="noopener" class="hover:text-white transition-colors">{company.address.full}</a>
        </div>
        <div class="flex items-start gap-2">
          <svg class="w-4 h-4 mt-0.5 text-brand-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          <div class="leading-snug">
            <a href={company.cta.phone} class="hover:text-white transition-colors block">{company.phone}</a>
            <span class="text-xs text-brand-gold">📱 Text us 24/7</span>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>{company.hoursDisplay}</span>
        </div>
      </div>
    </div>

    <!-- Products -->
    <div>
      <h3 class="text-white font-semibold mb-4">Flooring Products</h3>
      <ul class="space-y-2 text-sm">
        {services.map(s => (
          <li><a href={s.urlPath} class="hover:text-white hover:translate-x-1 transition-all inline-block">{s.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Services -->
    <div>
      <h3 class="text-white font-semibold mb-4">Our Services</h3>
      <ul class="space-y-2 text-sm mb-6">
        {installationServices.map(s => (
          <li><a href={s.urlPath} class="hover:text-white hover:translate-x-1 transition-all inline-block">{s.name}</a></li>
        ))}
        <li><a href="/blog/" class="hover:text-white hover:translate-x-1 transition-all inline-block">Flooring Blog</a></li>
        <li><a href="/faq/" class="hover:text-white hover:translate-x-1 transition-all inline-block">FAQ</a></li>
        <li><a href="/reviews/" class="hover:text-white hover:translate-x-1 transition-all inline-block">Customer Reviews</a></li>
        <li><a href="/financing/" class="hover:text-white hover:translate-x-1 transition-all inline-block">Financing Options</a></li>
        <li><a href="/free-estimate/" class="hover:text-white hover:translate-x-1 transition-all inline-block">Free Estimate</a></li>
      </ul>
    </div>

    <!-- Areas -->
    <div>
      <h3 class="text-white font-semibold mb-4">Areas We Serve</h3>
      <ul class="space-y-2 text-sm mb-6">
        {areas.map(a => (
          <li>
            <a href={`/flooring-in-${a.slug}/`} class="hover:text-white hover:translate-x-1 transition-all inline-block">
              {a.displayName}
            </a>
          </li>
        ))}
        <li><a href="/service-areas/" class="text-brand-gold hover:text-brand-gold-light font-medium">View All Areas →</a></li>
      </ul>
    </div>
  </div>

  <!-- CTA bar -->
  <div class="border-t border-white/10 bg-brand-navy">
    <div class="max-w-7xl mx-auto px-4 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-white font-heading font-semibold text-lg">
        Ready for new floors? Get your free estimate today.
      </div>
      <a href="/free-estimate/" class="btn-primary whitespace-nowrap">
        Schedule Free Estimate
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col md:flex-row items-center md:items-end justify-between gap-4">
      <!-- Left: logo + copyright -->
      <div class="flex flex-col items-center md:items-start gap-2">
        <img
          src="/images/all-about-floors-nw-logo.webp"
          alt="All About Floors NW"
          class="h-8 w-auto max-w-[160px] object-contain"
          width="160"
          height="32"
          loading="lazy"
        />
        <div class="text-xs text-gray-500">
          © {new Date().getFullYear()} {company.name}. All rights reserved.
        </div>
        <div class="flex gap-3 text-xs text-gray-500">
          <a href="/privacy-policy/" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
          <span class="text-gray-700">·</span>
          <a href="/sitemap-index.xml" class="hover:text-gray-300 transition-colors">Sitemap</a>
        </div>
      </div>

      <!-- Right: Thorwell Group credit -->
      <a
        href="https://thorwellgroup.com"
        target="_blank"
        rel="noopener"
        class="group flex flex-col items-center md:items-end gap-0.5 text-gray-400 hover:text-white transition-colors"
        style="font-family: 'Raleway', sans-serif; font-weight: 400;"
      >
        <span class="text-xs uppercase tracking-widest text-gray-500 group-hover:text-gray-400 transition-colors">
          Site designed and hosted by
        </span>
        <span class="text-lg md:text-xl leading-none">
          Thor<span style="color: #CBFBB4;">w</span>ell Group
        </span>
        <span class="text-xs md:text-sm text-gray-500 group-hover:text-gray-400 transition-colors">
          Future of Flooring
        </span>
      </a>
    </div>
  </div>
</footer>
