---
import { company } from '@data/company';

interface Props {
  title?: string;
}

const { title = company.experienceTrademark } = Astro.props;

const steps = [
  {
    number: '01',
    title: 'Schedule a Free Consultation',
    description: 'Call us or submit a request online — or text us 24/7. We\'ll schedule a free in-home visit at a time that works for you, evening appointments available.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  },
  {
    number: '02',
    title: 'Expert Advice & Free Quote',
    description: 'Our flooring expert visits your home with samples, takes precise measurements, and provides a transparent, no-obligation quote within 24 hours.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>`,
  },
  {
    number: '03',
    title: 'Professional Installation',
    description: 'Our certified installation crews arrive on time, protect your home, move furniture, and complete your project with precision and craftsmanship.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    number: '04',
    title: 'Follow-Up & Support',
    description: 'We check in within 10 days of project completion to ensure everything looks perfect and you\'re completely satisfied. Our warranty has you covered.',
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  },
];
---

<section class="py-20 bg-brand-light">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-14" data-animate="fade-up">
      <span class="badge-gold mb-3">Our Process</span>
      <h2 class="section-heading mt-2">{title}</h2>
      <p class="section-subheading mx-auto text-center">From the first call to the final inspection, we make getting beautiful new floors simple, stress-free, and satisfying.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class="relative text-center group" data-animate="fade-up" data-delay={String(i + 1)}>
          <!-- Connector line (desktop) -->
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-12 left-[calc(50%+3rem)] right-[-50%] h-0.5 bg-brand-gold/30 z-0"></div>
          )}
          <!-- Circle -->
          <div class="relative z-10 w-24 h-24 mx-auto mb-5 rounded-full bg-brand-navy text-white flex flex-col items-center justify-center shadow-lg group-hover:bg-brand-gold transition-colors duration-300">
            <div set:html={step.icon} />
            <span class="text-xs font-bold opacity-70 mt-0.5">STEP {step.number}</span>
          </div>
          <h3 class="font-heading font-semibold text-brand-navy text-lg mb-2">{step.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/free-estimate/" class="btn-primary">
        Start Your Free Estimate
      </a>
    </div>
  </div>
</section>
