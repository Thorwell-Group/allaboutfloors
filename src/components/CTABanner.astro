---
import { company } from '@data/company';

interface Props {
  heading?: string;
  subtext?: string;
  ctaText?: string;
  ctaHref?: string;
  variant?: 'navy' | 'gold' | 'light';
}

const {
  heading = 'Ready to Transform Your Floors?',
  subtext = 'Get a free in-home estimate from Vancouver\'s most trusted flooring experts. No pressure, no obligation.',
  ctaText = 'Get Your Free Estimate',
  ctaHref = '/free-estimate/',
  variant = 'navy',
} = Astro.props;

const bgClass = {
  navy: 'bg-brand-navy',
  gold: 'bg-brand-gold',
  light: 'bg-brand-light',
}[variant];

const textClass = {
  navy: 'text-white',
  gold: 'text-white',
  light: 'text-brand-navy',
}[variant];

const subTextClass = {
  navy: 'text-gray-300',
  gold: 'text-white/80',
  light: 'text-gray-600',
}[variant];
---

<section class={`py-16 ${bgClass}`}>
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class={`font-heading font-bold text-3xl md:text-4xl mb-4 ${textClass}`}>
      {heading}
    </h2>
    <p class={`text-lg mb-8 ${subTextClass}`}>{subtext}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={ctaHref} class="btn-primary text-base px-8 py-3.5">
        {ctaText}
      </a>
      <a href={company.cta.phone} class="btn-outline-white text-base px-8 py-3.5"
        class:list={[variant === 'light' && 'border-brand-navy text-brand-navy hover:bg-brand-navy/10']}
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Call {company.phone}
      </a>
    </div>

    <!-- Trust row -->
    <div class={`mt-8 flex flex-wrap justify-center gap-6 text-sm ${subTextClass}`}>
      <span>✔ Free In-Home Estimates</span>
      <span>✔ {company.yearsExperience} Years of Experience</span>
      <span>✔ Licensed & Insured</span>
      <span>✔ 5-Star Google Rated</span>
    </div>
  </div>
</section>
