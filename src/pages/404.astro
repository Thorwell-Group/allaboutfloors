---
import BaseLayout from '@layouts/BaseLayout.astro';
import { company } from '@data/company';
---

<BaseLayout
  title="Page Not Found | All About Floors NW"
  description="The page you're looking for could not be found."
  noIndex={true}
>
  <div class="min-h-[70vh] flex items-center justify-center bg-brand-light">
    <div class="text-center px-4">
      <div class="text-8xl font-heading font-bold text-brand-gold mb-4">404</div>
      <h1 class="font-heading font-bold text-3xl text-brand-navy mb-4">Page Not Found</h1>
      <p class="text-gray-600 mb-8 max-w-md mx-auto">
        We couldn't find the page you were looking for. You may have followed an outdated link or mistyped the address.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="btn-primary">Go to Homepage</a>
        <a href="/service-areas/" class="btn-secondary">Service Areas</a>
        <a href="/free-estimate/" class="btn-secondary">Get Free Estimate</a>
      </div>
    </div>
  </div>
</BaseLayout>
