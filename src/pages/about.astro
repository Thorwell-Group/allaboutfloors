---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import CTABanner from '@components/CTABanner.astro';
import BrandLogos from '@components/BrandLogos.astro';
import ReviewsSection from '@components/ReviewsSection.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { company } from '@data/company';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `About ${company.name}`,
  description: company.description,
  url: 'https://www.allaboutfloorsnw.com/about/',
  mainEntity: {
    '@type': 'LocalBusiness',
    name: company.name,
    foundingDate: company.founded,
    address: {
      '@type': 'PostalAddress',
      streetAddress: company.address.street,
      addressLocality: company.address.city,
      addressRegion: company.address.state,
      postalCode: company.address.zip,
      addressCountry: 'US',
    },
    telephone: company.phoneDashes,
  },
};
---

<BaseLayout
  title="About All About Floors NW | Vancouver, WA Flooring Experts Since 1999"
  description="Learn about All About Floors NW, Vancouver, WA's locally owned flooring company with 25+ years of experience. Meet our team, see our story, and discover why thousands of Clark County homeowners choose us."
  schema={schema}
>
  <Hero
    heading="About All About Floors NW"
    subheading="Vancouver's locally owned flooring company, serving Clark County and the Portland metro with integrity and expertise since 1999."
    image="/images/about-all-about-floors-nw-team-vancouver-wa.webp"
    imageAlt="The All About Floors NW team in their Vancouver, WA showroom"
    compact={true}
    badge="Est. 1999 · Locally Owned"
  />

  <Breadcrumb items={[{ label: 'About Us' }]} />

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div>
          <span class="badge-gold mb-4">Our Story</span>
          <h2 class="section-heading mb-5">More Than 25 Years of Flooring Excellence in Vancouver, WA</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            All About Floors NW was founded in 1999 with a simple mission: to bring the highest quality flooring products and professional installation services to Vancouver, WA and the Pacific Northwest, backed by honest pricing and exceptional customer care.
          </p>
          <p class="text-gray-700 leading-relaxed mb-4">
            What started as a small showroom has grown into one of Clark County's most respected flooring destinations. Over the past 25+ years, we've helped thousands of homeowners, contractors, designers, and business owners transform their spaces with beautiful, durable floors.
          </p>
          <p class="text-gray-700 leading-relaxed mb-6">
            We remain proudly independent and locally owned. That means when you work with us, you're working directly with our experienced team, not a franchise call center. Every estimate, every installation, every follow-up is personal and professional.
          </p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: 'Founded', value: '1999' },
              { label: 'Projects Completed', value: '5,000+' },
              { label: 'Years of Experience', value: '25+' },
              { label: 'on Google', value: '4.9 ★' },
            ].map(stat => (
              <div class="bg-brand-light rounded-xl p-4 text-center">
                <div class="text-2xl font-heading font-bold text-brand-navy">{stat.value}</div>
                <div class="text-sm text-gray-500 mt-0.5">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="space-y-4">
          <img
            src="/images/all-about-floors-nw-showroom-interior-vancouver-wa.webp"
            alt="All About Floors NW showroom interior featuring carpet and hardwood displays in Vancouver, WA"
            class="rounded-2xl shadow-lg w-full object-cover aspect-video"
            loading="lazy"
            width="700"
            height="394"
          />
          <img
            src="/images/TeamWorking.webp"
            alt="All About Floors NW professional installation crew at work in Clark County, WA"
            class="rounded-2xl shadow-lg w-full object-cover aspect-video"
            loading="lazy"
            width="700"
            height="394"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="section-heading">What Sets Us Apart</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
            title: 'Locally Owned & Operated',
            desc: 'We are your Clark County neighbors, not a franchise or big-box store. Our reputation is built on every home we touch in Vancouver, Camas, Battle Ground, and beyond.',
          },
          {
            icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
            title: 'Expert Installation Crews',
            desc: 'The independent flooring professionals we work with are heavily trained, background-checked, and dedicated to quality craftsmanship, never unknown or unvetted.',
          },
          {
            icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
            title: 'Transparent Pricing',
            desc: 'No bait-and-switch, no hidden fees. Our free in-home estimates include everything, materials, labor, underlayment, and disposal. What we quote is what you pay.',
          },
        ].map(val => (
          <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
            <div class="w-16 h-16 mx-auto mb-4 bg-brand-navy text-white rounded-2xl flex items-center justify-center">
              <Fragment set:html={val.icon} />
            </div>
            <h3 class="font-heading font-semibold text-brand-navy text-xl mb-3">{val.title}</h3>
            <p class="text-gray-600 leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Location section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="section-heading mb-5">Visit Our Vancouver, WA Showroom</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            Our showroom at <strong>{company.address.full}</strong> is stocked with hundreds of flooring samples from the world's leading brands. Come in and walk on the floors, see the colors in real light, and talk with our knowledgeable flooring consultants.
          </p>
          <div class="space-y-3 text-gray-700 mb-2">
            <div class="flex items-center gap-3"><span class="font-semibold w-16">Mon–Fri:</span> 9:00 AM – 6:00 PM</div>
            <div class="flex items-center gap-3"><span class="font-semibold w-16">Saturday:</span> Closed</div>
            <div class="flex items-center gap-3"><span class="font-semibold w-16">Sunday:</span> Closed</div>
          </div>
          <div class="text-brand-gold font-semibold text-sm mb-6">📱 Text us 24/7 — we reply fast, day or night.</div>
          <a href={company.googleMapsUrl} target="_blank" rel="noopener" class="btn-secondary">
            Get Directions
          </a>
        </div>
        <div>
          <iframe
            src={company.mapEmbedUrl}
            width="100%"
            height="350"
            style="border:0; border-radius:1rem;"
            allowfullscreen
            loading="lazy"
            title="All About Floors NW location in Vancouver, WA"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <ReviewsSection title="What Our Vancouver Neighbors Say" max={3} />
  <BrandLogos />
  <CTABanner heading="Come Visit Us or Schedule Your Free Estimate" subtext="Our showroom is open 6 days a week. Or let us come to you, free in-home estimates available throughout Clark County and the Portland metro." />
</BaseLayout>
