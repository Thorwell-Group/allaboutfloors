---
// Legacy redirect — the funnel is now in-home only.
// Any traffic that still hits /book-in-store/ flows to /book-in-home/.
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="canonical" href="https://www.allaboutfloorsnw.com/book-in-home/" />
    <meta http-equiv="refresh" content="0; url=/book-in-home/" />
    <script is:inline>
      (function () {
        var target = '/book-in-home/' + (window.location.search || '') + (window.location.hash || '');
        window.location.replace(target);
      })();
    </script>
  </head>
  <body>
    <p>Redirecting to <a href="/book-in-home/">/book-in-home/</a>…</p>
  </body>
</html>
