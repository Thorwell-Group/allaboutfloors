---
import BaseHead from '@components/BaseHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  noIndex?: boolean;
  schema?: object | object[];
  bare?: boolean;
}

const { title, description, canonicalURL, ogImage, noIndex, schema, bare = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
      noIndex={noIndex}
    />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(
        Array.isArray(schema) ? { '@context': 'https://schema.org', '@graph': schema } : schema
      )} />
    )}
    <slot name="head" />

    {/* Ad attribution capture: reads UTMs + Meta click IDs from the URL/cookies,
        persists first-touch across funnel hops, and appends them to every GHL
        iframe src so the data lands on the contact. */}
    <script is:inline>
      (function () {
        var KEYS = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term',
                    'campaign_id','adset_id','ad_id','fbclid','fbc','fbp'];
        var STORE = 'tw_attrib';
        function getCookie(n){var m=document.cookie.match('(^|;)\\s*'+n+'\\s*=\\s*([^;]+)');return m?decodeURIComponent(m.pop()):'';}

        var params = new URLSearchParams(window.location.search), data = {};
        KEYS.forEach(function(k){ var v=params.get(k); if(v) data[k]=v; });
        var fbp=getCookie('_fbp'), fbc=getCookie('_fbc'), fbclid=params.get('fbclid')||'';
        if(!fbc && fbclid) fbc='fb.1.'+Date.now()+'.'+fbclid;
        if(fbclid) data.fbclid=fbclid; if(fbc) data.fbc=fbc; if(fbp) data.fbp=fbp;

        var stored={}; try{ stored=JSON.parse(localStorage.getItem(STORE)||'{}'); }catch(e){}
        var merged={}; KEYS.forEach(function(k){ merged[k]=data[k]||stored[k]||''; });
        if(fbp) merged.fbp=fbp; if(fbc) merged.fbc=fbc;
        try{ localStorage.setItem(STORE, JSON.stringify(merged)); }catch(e){}
        data = merged;

        function tagIframes(){
          document.querySelectorAll(
            'iframe[src*="/widget/survey/"],iframe[src*="/widget/booking/"],iframe[src*="/widget/form/"],' +
            'iframe[src*="leadconnectorhq.com"],iframe[src*="msgsndr.com"],iframe[src*="lc.thorwellgroup.com"]'
          ).forEach(function(f){
            if(f.getAttribute('data-tw')==='1') return;
            var src=f.getAttribute('src'); if(!src) return;
            var u; try{ u=new URL(src, window.location.origin);}catch(e){ return; }
            KEYS.forEach(function(k){ if(data[k] && !u.searchParams.has(k)) u.searchParams.set(k,data[k]); });
            f.setAttribute('data-tw','1');
            if(u.toString()!==src) f.setAttribute('src', u.toString());
          });
        }
        function fillInputs(){
          KEYS.forEach(function(k){ if(!data[k]) return;
            var el=document.querySelector('input[name="'+k+'"],input#'+k+',input[data-q="'+k+'"]');
            if(el){ el.value=data[k]; el.dispatchEvent(new Event('input',{bubbles:true})); el.dispatchEvent(new Event('change',{bubbles:true})); }
          });
        }
        function run(){ tagIframes(); fillInputs(); }
        try{ new MutationObserver(run).observe(document.documentElement,{childList:true,subtree:true}); }catch(e){}
        if(document.readyState!=='loading') run();
        document.addEventListener('DOMContentLoaded', run);
        setTimeout(run,1000); setTimeout(run,3000);
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    {!bare && <Header />}
    <main class="flex-1">
      <slot />
    </main>
    {!bare && <Footer />}

    <!-- Scroll-triggered animations + counting numbers -->
    <script>
      (() => {
        function startCounter(el) {
          const target = parseInt(el.dataset.countTo, 10);
          const suffix = el.dataset.countSuffix || '';
          const display = el.querySelector('[data-count-display]');
          if (!display || isNaN(target)) return;
          const duration = 1800;
          const start = performance.now();
          const tick = (now) => {
            const p = Math.min((now - start) / duration, 1);
            const ease = 1 - Math.pow(1 - p, 3);
            display.textContent = Math.round(ease * target) + suffix;
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach(e => {
              if (!e.isIntersecting) return;
              e.target.classList.add('visible');
              if (e.target.dataset.countTo) startCounter(e.target);
              io.unobserve(e.target);
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        document.querySelectorAll('[data-animate], [data-count-to]').forEach(el => io.observe(el));
      })();
    </script>

    <!-- Alpine.js scroll-to-top button -->
    <button
      x-data="{ show: false }"
      x-init="window.addEventListener('scroll', () => show = window.scrollY > 400)"
      x-show="show"
      x-transition
      @click="window.scrollTo({ top: 0, behavior: 'smooth' })"
      class="fixed bottom-6 right-6 z-50 bg-brand-navy text-white w-11 h-11 rounded-full shadow-lg flex items-center justify-center hover:bg-brand-gold transition-colors duration-200"
      aria-label="Back to top"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
      </svg>
    </button>
  </body>
</html>
